# Copy to `.env` and fill in from your Supabase project → Settings → API.
# Cloud sync (accounts + character backup) activates in the WEB build only when BOTH are set.
# The desktop/Android (Tauri) builds ignore these and stay local-only.
#
# Use the PUBLISHABLE / anon key — NEVER the service_role (secret) key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
