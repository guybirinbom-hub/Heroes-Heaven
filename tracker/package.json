{
  "name": "heroes-heaven-tracker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data": "node scripts/build-data.mjs",
    "build": "tsc -b && vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:css": "node scripts/build-scoped-css.mjs && node scripts/verify-scoped-css.mjs",
    "verify:css": "node scripts/verify-scoped-css.mjs"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "dompurify": "^3.4.11",
    "immer": "^11.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "postcss-prefix-selector": "^2.1.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
