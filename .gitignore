# dependencies
node_modules

# build output
dist
dist-ssr
*.local

# Local env (Supabase URL + publishable key). The publishable key is public-safe, but keep env
# out of git; production values live in the Cloudflare Pages dashboard. .env.example is committed.
.env
.env.*
!.env.example

# editor / os
.DS_Store
.vscode/*
!.vscode/extensions.json

# logs
*.log
npm-debug.log*

# Tauri
src-tauri/target
src-tauri/gen

# Foundry source clone for the data importer (not tracked)
.import-src/

# Android release signing — NEVER commit the keystore or its passwords.
# BACK THESE UP somewhere safe: losing the keystore means release updates can no longer be installed.
signing/
